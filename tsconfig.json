{
  "extends": "expo/tsconfig.base",
    "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "env.d.ts"
  ],
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "lib": ["ESNext"],
    "ignoreDeprecations": "6.0",
    "paths": {
      "@features/*": ["src/features/*"],
      "@shared/*": ["src/shared/*"],
    }
  },

}
